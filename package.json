{
  "name": "tinysa-flasher",
  "version": "0.1.0",
  "private": true,
  "author": "PhysicistJohn",
  "description": "Fail-closed standalone firmware updater for tinySA Ultra / Ultra+ ZS407",
  "type": "module",
  "main": "dist/main/main.js",
  "packageManager": "npm@10.9.8",
  "scripts": {
    "clean": "node tools/clean.mjs all",
    "clean:dist": "node tools/clean.mjs dist",
    "clean:release": "node tools/clean.mjs release",
    "dev": "node tools/dev.mjs",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:safe": "node tools/dev-safe.mjs",
    "build": "npm run clean:dist && npm run build:main && vite build",
    "build:main": "tsup src/main/main.ts --format esm --target node22 --out-dir dist/main --external electron --external serialport && tsup --config tsup.preload.config.ts",
    "lint": "eslint . --max-warnings 0",
    "check:contracts": "node tools/verify-contracts.mjs && node tools/verify-interface-contracts.mjs",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:release-tools": "node --test tools/release-gate.test.mjs tools/release-provenance.test.mjs",
    "inspect:evidence": "node tools/inspect-evidence.mjs",
    "release:assert-clean": "node tools/release-gate.mjs assert-clean",
    "release:begin": "node tools/release-gate.mjs begin",
    "release:checkpoint": "node tools/release-gate.mjs checkpoint",
    "release:finish": "node tools/release-gate.mjs finish",
    "artifacts:provenance": "node tools/release-provenance.mjs write",
    "artifacts:provenance:verify": "node tools/release-provenance.mjs verify",
    "artifacts:checksums": "node tools/release-artifacts.mjs write",
    "artifacts:verify": "node tools/release-artifacts.mjs verify",
    "smoke:package": "node tools/smoke-package.mjs",
    "check": "npm run lint && npm run check:contracts && npm run typecheck && npm run test:coverage && npm run test:release-tools && npm run build",
    "package:mac": "npm run release:begin && npm run clean:release && npm run check && npm run release:checkpoint && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip && npm run release:checkpoint && npm run smoke:package && npm run artifacts:provenance && npm run artifacts:checksums && npm run artifacts:verify && npm run artifacts:provenance:verify && npm run release:finish"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "serialport": "13.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electron/asar": "4.2.0",
    "@electron/fuses": "2.1.3",
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "tsup": "8.5.0",
    "typescript": "5.9.2",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.23.1 <23",
    "npm": "10.9.8"
  },
  "build": {
    "appId": "com.physicistjohn.tinysa-flasher",
    "productName": "TinySA Flasher",
    "afterPack": "./tools/after-pack.mjs",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/main/**",
      "dist/renderer/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/TinySAFlasherIcon.png",
      "minimumSystemVersion": "12.0",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": "-",
      "extendInfo": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": false,
          "NSExceptionDomains": {
            "127.0.0.1": {
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": false
            },
            "localhost": {
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": false
            }
          }
        }
      },
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
