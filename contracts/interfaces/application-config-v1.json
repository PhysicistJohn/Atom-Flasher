{
  "$schema": "../schemas/interface-contract-v2.schema.json",
  "contractId": "tinysa-flasher-application-config",
  "contractVersion": 1,
  "kind": "configuration",
  "owner": "desktop-composition-root",
  "provider": "process environment and Electron packaging state",
  "consumers": [
    "renderer loader",
    "DFU tool discovery"
  ],
  "compatibility": "exact-version",
  "typeDefinitions": {
    "VITE_DEV_SERVER_URL? and isPackaged": {
      "sourceModule": "src/main/config.ts",
      "valueExport": "loadApplicationConfig",
      "platformType": "{ VITE_DEV_SERVER_URL?: string; isPackaged: boolean }"
    },
    "RendererTrust": {
      "sourceModule": "src/main/security.ts",
      "typeExport": "RendererTrust",
      "sourceSignature": "export type RendererTrust = | { mode: 'development'; origin: string } | { mode: 'production'; url: string };"
    },
    "TINYSA_DFU_UTIL? and PATH": {
      "sourceModule": "src/main/config.ts",
      "valueExport": "loadApplicationConfig",
      "platformType": "{ TINYSA_DFU_UTIL?: string; PATH?: string }"
    },
    "DfuToolConfiguration": {
      "sourceModule": "src/main/config.ts",
      "typeExport": "ApplicationConfig",
      "sourceSignature": "export interface ApplicationConfig { readonly developmentServerUrl?: URL; readonly dfuUtilPath?: string; readonly executableSearchPath: string; }"
    }
  },
  "capabilities": [
    {
      "capabilityId": "renderer-location",
      "input": {
        "typeRef": "VITE_DEV_SERVER_URL? and isPackaged",
        "description": "Optional local development URL plus authoritative packaging state."
      },
      "output": {
        "typeRef": "RendererTrust",
        "description": "Exactly one development-origin or production-file trust variant."
      },
      "errors": [
        {
          "code": "INVALID_APPLICATION_CONFIG",
          "retryability": "never",
          "description": "The configured development URL is not unauthenticated local HTTP."
        }
      ],
      "invariants": [
        "Packaged applications ignore every development-server override."
      ]
    },
    {
      "capabilityId": "dfu-tool-location",
      "input": {
        "typeRef": "TINYSA_DFU_UTIL? and PATH",
        "description": "Optional explicit executable plus bounded host search path."
      },
      "output": {
        "typeRef": "DfuToolConfiguration",
        "description": "Normalized executable discovery configuration."
      },
      "errors": [
        {
          "code": "INVALID_APPLICATION_CONFIG",
          "retryability": "never",
          "description": "An explicit path is empty, malformed, or not executable."
        }
      ],
      "invariants": [
        "Environment configuration never bypasses exact dfu-util version admission."
      ]
    }
  ],
  "sourceProjections": [
    {
      "sourceModule": "src/main/config.ts",
      "symbol": "loadApplicationConfig",
      "symbolKind": "function",
      "members": [
        {
          "sourceMember": "loadApplicationConfig",
          "capabilityId": "dfu-tool-location",
          "sourceSignature": "loadApplicationConfig(environment: NodeJS.ProcessEnv, isPackaged: boolean): ApplicationConfig"
        }
      ]
    },
    {
      "sourceModule": "src/main/security.ts",
      "symbol": "validateDevelopmentServerUrl",
      "symbolKind": "function",
      "members": [
        {
          "sourceMember": "validateDevelopmentServerUrl",
          "capabilityId": "renderer-location",
          "sourceSignature": "validateDevelopmentServerUrl(value: string): URL"
        }
      ]
    },
    {
      "sourceModule": "src/main/security.ts",
      "symbol": "selectDevelopmentServerUrl",
      "symbolKind": "function",
      "members": [
        {
          "sourceMember": "selectDevelopmentServerUrl",
          "capabilityId": "renderer-location",
          "sourceSignature": "selectDevelopmentServerUrl(value: string | undefined, isPackaged: boolean): URL | undefined"
        }
      ]
    },
    {
      "sourceModule": "src/main/security.ts",
      "symbol": "isTrustedRendererUrl",
      "symbolKind": "function",
      "members": [
        {
          "sourceMember": "isTrustedRendererUrl",
          "capabilityId": "renderer-location",
          "sourceSignature": "isTrustedRendererUrl(actual: string, expected: RendererTrust | undefined): boolean"
        }
      ]
    }
  ],
  "sourceOfTruth": [
    "src/main/config.ts",
    "src/main/security.ts",
    "src/main/main.ts",
    "src/dfu/dfu-util.ts"
  ]
}
