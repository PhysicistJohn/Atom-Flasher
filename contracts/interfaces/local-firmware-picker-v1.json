{
  "$schema": "../schemas/interface-contract-v2.schema.json",
  "contractId": "tinysa-flasher-local-firmware-picker",
  "contractVersion": 1,
  "kind": "runtime-port",
  "owner": "desktop-composition-root",
  "provider": "LocalFirmwareTargetPicker",
  "consumers": [
    "FlasherApplication"
  ],
  "compatibility": "exact-version",
  "typeDefinitions": {
    "LocalFirmwareTargetPicker": {
      "sourceModule": "src/main/local-firmware-target-picker.ts",
      "typeExport": "LocalFirmwareTargetPicker",
      "sourceSignature": "class LocalFirmwareTargetPicker { selectLocalFirmwareTarget(): Promise<LocalFirmwareTargetSelection | undefined>; reopenLocalFirmwareTarget(target: LocalCustomFirmwareTarget): Promise<LocalFirmwareTargetSelection> }"
    },
    "LocalFirmwareManifestDialog": {
      "sourceModule": "src/main/local-firmware-target-picker.ts",
      "typeExport": "LocalFirmwareManifestDialog",
      "sourceSignature": "export interface LocalFirmwareManifestDialog { chooseManifest(parent: BrowserWindow | undefined): Promise<string | undefined>; }"
    },
    "ManifestPathOrUndefined": {
      "sourceModule": "platform:node",
      "platformType": "string | undefined"
    },
    "LocalFirmwareTargetSelection": {
      "sourceModule": "src/application/flasher-application.ts",
      "typeExport": "LocalFirmwareTargetSelection",
      "sourceSignature": "export interface LocalFirmwareTargetSelection { readonly target: LocalCustomFirmwareTarget; readonly artifact: AdmittedFirmwareArtifact; }"
    },
    "LocalCustomFirmwareTarget": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "localCustomFirmwareTargetSchema",
      "typeExport": "LocalCustomFirmwareTarget",
      "sourceSignature": "export type LocalCustomFirmwareTarget = z.infer<typeof localCustomFirmwareTargetSchema>;"
    }
  },
  "capabilities": [
    {
      "capabilityId": "dialog-choose-manifest",
      "input": {
        "typeRef": "LocalFirmwareManifestDialog",
        "description": "The native dialog capability plus the current trusted parent window, if one exists."
      },
      "output": {
        "typeRef": "ManifestPathOrUndefined",
        "description": "A native-selected path or cancellation, never renderer input."
      },
      "errors": [
        {
          "code": "NATIVE_DIALOG_FAILED",
          "retryability": "safe",
          "description": "The operating-system file dialog failed."
        }
      ],
      "invariants": [
        "Selection is restricted to one file and no path crosses renderer IPC."
      ]
    },
    {
      "capabilityId": "picker-select-local-target",
      "input": {
        "typeRef": "LocalFirmwareTargetPicker",
        "description": "The main-process picker adapter."
      },
      "output": {
        "typeRef": "LocalFirmwareTargetSelection",
        "description": "A validated target/descriptor-opening artifact pair or cancellation."
      },
      "errors": [
        {
          "code": "ARTIFACT_REJECTED",
          "retryability": "never",
          "description": "The chosen manifest or artifact failed strict admission."
        }
      ],
      "invariants": [
        "The selection binds target and manifest identities to an openVerified descriptor capability; neither the selected nor app-owned path crosses renderer IPC."
      ]
    },
    {
      "capabilityId": "picker-reopen-local-target",
      "input": {
        "typeRef": "LocalCustomFirmwareTarget",
        "description": "A recovered strict custom target."
      },
      "output": {
        "typeRef": "LocalFirmwareTargetSelection",
        "description": "A rebound target/artifact capability from deterministic app-owned paths."
      },
      "errors": [
        {
          "code": "ARTIFACT_REJECTED",
          "retryability": "never",
          "description": "App-owned files no longer reproduce the persisted target."
        }
      ],
      "invariants": [
        "Recovery never trusts a persisted arbitrary filesystem path."
      ]
    }
  ],
  "sourceProjections": [
    {
      "sourceModule": "src/main/local-firmware-target-picker.ts",
      "symbol": "LocalFirmwareManifestDialog",
      "symbolKind": "interface",
      "members": [
        {
          "sourceMember": "chooseManifest",
          "capabilityId": "dialog-choose-manifest",
          "sourceSignature": "chooseManifest(parent: BrowserWindow | undefined): Promise<string | undefined>"
        }
      ]
    },
    {
      "sourceModule": "src/main/local-firmware-target-picker.ts",
      "symbol": "LocalFirmwareTargetPicker",
      "symbolKind": "class",
      "members": [
        {
          "sourceMember": "selectLocalFirmwareTarget",
          "capabilityId": "picker-select-local-target",
          "sourceSignature": "selectLocalFirmwareTarget(): Promise<LocalFirmwareTargetSelection | undefined>"
        },
        {
          "sourceMember": "reopenLocalFirmwareTarget",
          "capabilityId": "picker-reopen-local-target",
          "sourceSignature": "reopenLocalFirmwareTarget(target: LocalCustomFirmwareTarget): Promise<LocalFirmwareTargetSelection>"
        }
      ]
    }
  ],
  "sourceOfTruth": [
    "src/main/local-firmware-target-picker.ts",
    "src/core/local-firmware-build.ts",
    "src/core/contracts.ts",
    "src/application/flasher-application.ts"
  ]
}
