{
  "$schema": "../schemas/interface-contract-v2.schema.json",
  "contractId": "tinysa-flasher-runtime-ports",
  "contractVersion": 2,
  "kind": "runtime-port",
  "owner": "firmware-update-control-plane",
  "provider": "production runtime adapters",
  "consumers": [
    "FirmwareArtifactStore",
    "FirmwareUpdater",
    "DFU adapter"
  ],
  "compatibility": "exact-version",
  "typeDefinitions": {
    "ArtifactStore": {
      "sourceModule": "src/core/firmware-artifact.ts",
      "typeExport": "FirmwareArtifactStore",
      "sourceSignature": "class FirmwareArtifactStore { download(): Promise<FirmwareArtifact>; inspect(): Promise<FirmwareArtifact | undefined>; readVerified(): Promise<Uint8Array>; openVerified(): Promise<VerifiedFirmwareArtifact> }"
    },
    "ArtifactTransportPort": {
      "sourceModule": "src/core/firmware-artifact.ts",
      "typeExport": "FirmwareArtifactTransportPort",
      "sourceSignature": "export interface FirmwareArtifactTransportPort { fetch(url: string, init: RequestInit): Promise<Response>; }"
    },
    "ArtifactVerificationPort": {
      "sourceModule": "src/core/firmware-artifact.ts",
      "typeExport": "FirmwareArtifactVerificationPort",
      "sourceSignature": "export interface FirmwareArtifactVerificationPort { verify(bytes: Uint8Array): void; }"
    },
    "ArtifactClockPort": {
      "sourceModule": "src/core/firmware-artifact.ts",
      "typeExport": "FirmwareArtifactClockPort",
      "sourceSignature": "export interface FirmwareArtifactClockPort { now(): Date; }"
    },
    "ArtifactIdentityPort": {
      "sourceModule": "src/core/firmware-artifact.ts",
      "typeExport": "FirmwareArtifactIdentityPort",
      "sourceSignature": "export interface FirmwareArtifactIdentityPort { randomUuid(): string; }"
    },
    "ArtifactTimeAndIdentityPort": {
      "sourceModule": "src/core/firmware-artifact.ts",
      "typeExport": "FirmwareArtifactTimeAndIdentityPort",
      "sourceSignature": "export interface FirmwareArtifactTimeAndIdentityPort extends FirmwareArtifactClockPort, FirmwareArtifactIdentityPort {}"
    },
    "ArtifactRuntime": {
      "sourceModule": "src/core/firmware-artifact.ts",
      "typeExport": "FirmwareArtifactRuntime",
      "sourceSignature": "export interface FirmwareArtifactRuntime extends FirmwareArtifactTransportPort, FirmwareArtifactVerificationPort, FirmwareArtifactTimeAndIdentityPort {}"
    },
    "VerifiedFirmwareArtifact": {
      "sourceModule": "src/core/firmware-artifact.ts",
      "typeExport": "VerifiedFirmwareArtifact",
      "sourceSignature": "export interface VerifiedFirmwareArtifact { readonly descriptor: number; readonly bytes: Uint8Array; assertStable(): Promise<void>; close(): Promise<void>; }"
    },
    "VerifiedFirmwareFilePolicy": {
      "sourceModule": "src/core/firmware-artifact.ts",
      "typeExport": "VerifiedFirmwareFilePolicy",
      "sourceSignature": "export interface VerifiedFirmwareFilePolicy { readonly label: string; readonly maximumBytes: number; readonly exactBytes?: number; readonly requireSingleLink?: boolean; }"
    },
    "UpdateSnapshotPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareUpdateSnapshotPort",
      "sourceSignature": "export interface FirmwareUpdateSnapshotPort { snapshot(): DeviceSnapshot; }"
    },
    "UpdateDiagnosticsPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareUpdateDiagnosticsPort",
      "sourceSignature": "export interface FirmwareUpdateDiagnosticsPort { readDiagnostics(): Promise<DeviceDiagnostics>; }"
    },
    "UpdateScreenCapturePort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareUpdateScreenCapturePort",
      "sourceSignature": "export interface FirmwareUpdateScreenCapturePort { captureScreen(): Promise<ScreenFrame>; }"
    },
    "UpdateObservationPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareUpdateObservationPort",
      "sourceSignature": "export interface FirmwareUpdateObservationPort extends FirmwareUpdateSnapshotPort, FirmwareUpdateDiagnosticsPort, FirmwareUpdateScreenCapturePort {}"
    },
    "UpdateDisconnectPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareUpdateDisconnectPort",
      "sourceSignature": "export interface FirmwareUpdateDisconnectPort { disconnect(): Promise<void>; }"
    },
    "UpdateDiscoveryPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareUpdateDiscoveryPort",
      "sourceSignature": "export interface FirmwareUpdateDiscoveryPort { listDevices(): Promise<PortCandidate[]>; }"
    },
    "UpdateConnectPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareUpdateConnectPort",
      "sourceSignature": "export interface FirmwareUpdateConnectPort { connect(candidate: PortCandidate): Promise<DeviceSnapshot>; }"
    },
    "UpdateConnectionPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareUpdateConnectionPort",
      "sourceSignature": "export interface FirmwareUpdateConnectionPort extends FirmwareUpdateDisconnectPort, FirmwareUpdateDiscoveryPort, FirmwareUpdateConnectPort {}"
    },
    "UpdateDevice": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareUpdateDevice",
      "sourceSignature": "export interface FirmwareUpdateDevice extends FirmwareUpdateObservationPort, FirmwareUpdateConnectionPort {}"
    },
    "UpdaterArtifactFetchPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareArtifactFetchPort",
      "sourceSignature": "export interface FirmwareArtifactFetchPort { fetch(url: string, init: RequestInit): Promise<Response>; }"
    },
    "UpdaterArtifactVerificationPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareArtifactVerificationPort",
      "sourceSignature": "export interface FirmwareArtifactVerificationPort { verifyArtifact(bytes: Uint8Array): void; }"
    },
    "UpdaterArtifactPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareArtifactPort",
      "sourceSignature": "export interface FirmwareArtifactPort extends FirmwareArtifactFetchPort, FirmwareArtifactVerificationPort {}"
    },
    "FirmwareClockPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareClockPort",
      "sourceSignature": "export interface FirmwareClockPort { now(): Date; }"
    },
    "FirmwareIdentityPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareIdentityPort",
      "sourceSignature": "export interface FirmwareIdentityPort { randomUuid(): string; }"
    },
    "FirmwareDelayPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareDelayPort",
      "sourceSignature": "export interface FirmwareDelayPort { delay(milliseconds: number): Promise<void>; }"
    },
    "FirmwareTimeAndIdentityPort": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareTimeAndIdentityPort",
      "sourceSignature": "export interface FirmwareTimeAndIdentityPort extends FirmwareClockPort, FirmwareIdentityPort, FirmwareDelayPort {}"
    },
    "FirmwareUpdaterRuntime": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "FirmwareUpdaterRuntime",
      "sourceSignature": "export interface FirmwareUpdaterRuntime extends FirmwareArtifactPort, FirmwareTimeAndIdentityPort, DfuToolRuntime {}"
    },
    "AdmittedFirmwareArtifact": {
      "sourceModule": "src/core/firmware-updater.ts",
      "typeExport": "AdmittedFirmwareArtifact",
      "sourceSignature": "export interface AdmittedFirmwareArtifact { readonly targetId: string; openVerified(): Promise<VerifiedFirmwareArtifact>; }"
    },
    "DfuInspection": {
      "sourceModule": "src/dfu/dfu-util.ts",
      "typeExport": "DfuInspection",
      "sourceSignature": "export interface DfuInspection { deviceCount: number; identities: DfuIdentity[]; }"
    },
    "DfuFirmwareDescriptor": {
      "sourceModule": "src/dfu/dfu-util.ts",
      "typeExport": "DfuFirmwareDescriptor",
      "sourceSignature": "export interface DfuFirmwareDescriptor { readonly descriptor: number; }"
    },
    "DfuToolLocationPort": {
      "sourceModule": "src/dfu/dfu-util.ts",
      "typeExport": "DfuToolLocationPort",
      "sourceSignature": "export interface DfuToolLocationPort { locateDfuUtility(): Promise<string | undefined>; }"
    },
    "DfuCommandExecutionPort": {
      "sourceModule": "src/dfu/dfu-util.ts",
      "typeExport": "DfuCommandExecutionPort",
      "sourceSignature": "export interface DfuCommandExecutionPort { runExecutable(file: string, args: readonly string[], timeout: number): Promise<ExecutableResult>; }"
    },
    "DfuFlashExecutionPort": {
      "sourceModule": "src/dfu/dfu-util.ts",
      "typeExport": "DfuFlashExecutionPort",
      "sourceSignature": "export interface DfuFlashExecutionPort { runDfuExecutable( file: string, args: readonly string[], expectedDuration: number, onProgress: (progress: DfuTransferProgress) => void, firmware: DfuFirmwareDescriptor, ): Promise<DfuExecutionResult>; }"
    },
    "DfuToolRuntime": {
      "sourceModule": "src/dfu/dfu-util.ts",
      "typeExport": "DfuToolRuntime",
      "sourceSignature": "export interface DfuToolRuntime extends DfuToolLocationPort, DfuCommandExecutionPort, DfuFlashExecutionPort {}"
    },
    "FirmwareArtifact": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "firmwareArtifactSchema",
      "typeExport": "FirmwareArtifact",
      "sourceSignature": "export type FirmwareArtifact = z.infer<typeof firmwareArtifactSchema>;"
    },
    "DeviceSnapshot": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "deviceSnapshotSchema",
      "typeExport": "DeviceSnapshot",
      "sourceSignature": "export type DeviceSnapshot = z.infer<typeof deviceSnapshotSchema>;"
    },
    "DeviceDiagnostics": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "deviceDiagnosticsSchema",
      "typeExport": "DeviceDiagnostics",
      "sourceSignature": "export type DeviceDiagnostics = z.infer<typeof deviceDiagnosticsSchema>;"
    },
    "ScreenFrame": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "screenFrameSchema",
      "typeExport": "ScreenFrame",
      "sourceSignature": "export type ScreenFrame = z.infer<typeof screenFrameSchema>;"
    },
    "PortCandidateArray": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "portCandidateArraySchema",
      "typeExport": "PortCandidateArray",
      "sourceSignature": "export type PortCandidateArray = z.infer<typeof portCandidateArraySchema>;"
    },
    "ReadableByteResponse": {
      "sourceModule": "platform:web",
      "platformType": "Response"
    },
    "ExecutableResult": {
      "sourceModule": "src/dfu/dfu-util.ts",
      "runtimeValidator": "executableResultSchema",
      "typeExport": "ExecutableResult",
      "sourceSignature": "export type ExecutableResult = z.infer<typeof executableResultSchema>;"
    },
    "DfuExecutionResult": {
      "sourceModule": "src/dfu/dfu-util.ts",
      "runtimeValidator": "dfuExecutionResultSchema",
      "typeExport": "DfuExecutionResult",
      "sourceSignature": "export type DfuExecutionResult = z.infer<typeof dfuExecutionResultSchema>;"
    },
    "Uint8Array": {
      "sourceModule": "platform:ecmascript",
      "platformType": "Uint8Array"
    },
    "Date": {
      "sourceModule": "platform:ecmascript",
      "platformType": "Date"
    },
    "UuidV4": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "uuidSchema",
      "platformType": "string"
    },
    "PathOrUndefined": {
      "sourceModule": "platform:node",
      "platformType": "absolute path string | undefined"
    },
    "void": {
      "sourceModule": "platform:ecmascript",
      "platformType": "void"
    }
  },
  "capabilities": [
    {
      "capabilityId": "artifact-fetch",
      "input": {
        "typeRef": "ArtifactTransportPort",
        "description": "Untrusted URL and bounded request options."
      },
      "output": {
        "typeRef": "ReadableByteResponse",
        "description": "An untrusted response stream."
      },
      "errors": [
        {
          "code": "FIRMWARE_SOURCE_FAILED",
          "retryability": "safe",
          "description": "Transport failed."
        }
      ],
      "invariants": [
        "Transport never confers authenticity."
      ]
    },
    {
      "capabilityId": "artifact-verify",
      "input": {
        "typeRef": "ArtifactVerificationPort",
        "description": "Candidate OEM bytes."
      },
      "output": {
        "typeRef": "void",
        "description": "Success after exact pinned verification."
      },
      "errors": [
        {
          "code": "ARTIFACT_REJECTED",
          "retryability": "never",
          "description": "Length or SHA-256 differs."
        }
      ],
      "invariants": [
        "Verification is independent of transport."
      ]
    },
    {
      "capabilityId": "artifact-now",
      "input": {
        "typeRef": "ArtifactClockPort",
        "description": "Artifact evidence clock."
      },
      "output": {
        "typeRef": "Date",
        "description": "Valid current Date."
      },
      "errors": [
        {
          "code": "INVALID_RUNTIME_VALUE",
          "retryability": "never",
          "description": "Clock returned an invalid date."
        }
      ],
      "invariants": [
        "Evidence timestamps are ISO instants."
      ]
    },
    {
      "capabilityId": "artifact-random-uuid",
      "input": {
        "typeRef": "ArtifactIdentityPort",
        "description": "Artifact staging identity source."
      },
      "output": {
        "typeRef": "UuidV4",
        "description": "UUID-v4 staging identity."
      },
      "errors": [
        {
          "code": "INVALID_RUNTIME_VALUE",
          "retryability": "never",
          "description": "Identity is invalid."
        }
      ],
      "invariants": [
        "Production uses cryptographic randomUUID."
      ]
    },
    {
      "capabilityId": "artifact-runtime-composition",
      "input": {
        "typeRef": "ArtifactTimeAndIdentityPort",
        "description": "Clock and identity composition."
      },
      "output": {
        "typeRef": "ArtifactRuntime",
        "description": "Complete artifact runtime including transport and verifier."
      },
      "errors": [],
      "invariants": [
        "Every required leaf capability is explicit."
      ]
    },
    {
      "capabilityId": "artifact-store-download",
      "input": {
        "typeRef": "ArtifactStore",
        "description": "Canonical OEM artifact store."
      },
      "output": {
        "typeRef": "FirmwareArtifact",
        "description": "Verified create-once artifact evidence."
      },
      "errors": [
        {
          "code": "FIRMWARE_SOURCE_FAILED",
          "retryability": "safe",
          "description": "Fetch, verification, or durable install failed."
        }
      ],
      "invariants": [
        "Partial bytes never occupy the canonical path."
      ]
    },
    {
      "capabilityId": "artifact-store-inspect",
      "input": {
        "typeRef": "ArtifactStore",
        "description": "Canonical OEM artifact store."
      },
      "output": {
        "typeRef": "FirmwareArtifact",
        "description": "Verified evidence or absence."
      },
      "errors": [
        {
          "code": "ARTIFACT_REJECTED",
          "retryability": "never",
          "description": "Existing canonical bytes are unsafe."
        }
      ],
      "invariants": [
        "Inspection follows no symlink and repeats digest verification."
      ]
    },
    {
      "capabilityId": "artifact-store-read-verified",
      "input": {
        "typeRef": "ArtifactStore",
        "description": "Canonical OEM artifact store."
      },
      "output": {
        "typeRef": "Uint8Array",
        "description": "Fresh exact verified OEM bytes."
      },
      "errors": [
        {
          "code": "ARTIFACT_REJECTED",
          "retryability": "never",
          "description": "Canonical bytes changed or mismatch."
        }
      ],
      "invariants": [
        "Every write-path read verifies exact size and SHA-256."
      ]
    },
    {
      "capabilityId": "artifact-store-open-verified",
      "input": {
        "typeRef": "VerifiedFirmwareFilePolicy",
        "description": "Canonical path policy and byte verifier owned by ArtifactStore."
      },
      "output": {
        "typeRef": "VerifiedFirmwareArtifact",
        "description": "Open exact descriptor, verified bytes, stability assertion, and close capability."
      },
      "errors": [
        {
          "code": "ARTIFACT_REJECTED",
          "retryability": "never",
          "description": "Metadata, positioned read, verification, or stability checks failed."
        }
      ],
      "invariants": [
        "The descriptor remains open and its shared offset remains zero for child inheritance."
      ]
    },
    {
      "capabilityId": "verified-artifact-assert-stable",
      "input": {
        "typeRef": "VerifiedFirmwareArtifact",
        "description": "An open verified file description immediately before child spawn."
      },
      "output": {
        "typeRef": "void",
        "description": "Success only if the descriptor metadata is unchanged."
      },
      "errors": [
        {
          "code": "ARTIFACT_REJECTED",
          "retryability": "never",
          "description": "The open file changed after verification."
        }
      ],
      "invariants": [
        "No pathname is resolved for this check."
      ]
    },
    {
      "capabilityId": "verified-artifact-close",
      "input": {
        "typeRef": "VerifiedFirmwareArtifact",
        "description": "An open verified firmware descriptor."
      },
      "output": {
        "typeRef": "void",
        "description": "Idempotent descriptor close completion."
      },
      "errors": [],
      "invariants": [
        "The parent descriptor is closed after child exit or any pre-spawn failure."
      ]
    },
    {
      "capabilityId": "device-snapshot",
      "input": {
        "typeRef": "UpdateSnapshotPort",
        "description": "Firmware updater device observation port."
      },
      "output": {
        "typeRef": "DeviceSnapshot",
        "description": "Current validated device snapshot."
      },
      "errors": [],
      "invariants": [
        "Snapshot is synchronous."
      ]
    },
    {
      "capabilityId": "device-read-diagnostics",
      "input": {
        "typeRef": "UpdateDiagnosticsPort",
        "description": "Admitted ready device."
      },
      "output": {
        "typeRef": "DeviceDiagnostics",
        "description": "Exact identity, command, and telemetry observations."
      },
      "errors": [
        {
          "code": "DEVICE_SAFETY_FAULT",
          "retryability": "conditional",
          "description": "Live diagnostics failed."
        }
      ],
      "invariants": [
        "Diagnostics are collected with RF output off."
      ]
    },
    {
      "capabilityId": "device-capture-screen",
      "input": {
        "typeRef": "UpdateScreenCapturePort",
        "description": "Admitted ready device."
      },
      "output": {
        "typeRef": "ScreenFrame",
        "description": "Exact 480x320 RGB565 frame."
      },
      "errors": [
        {
          "code": "SCREEN_CAPTURE_FAILED",
          "retryability": "conditional",
          "description": "Frame capture failed."
        }
      ],
      "invariants": [
        "Frame length is exact."
      ]
    },
    {
      "capabilityId": "device-observation-composition",
      "input": {
        "typeRef": "UpdateObservationPort",
        "description": "Snapshot, diagnostics, and screen composition."
      },
      "output": {
        "typeRef": "UpdateDevice",
        "description": "Complete updater device capability."
      },
      "errors": [],
      "invariants": [
        "Observation remains separable from connection mutation."
      ]
    },
    {
      "capabilityId": "device-disconnect",
      "input": {
        "typeRef": "UpdateDisconnectPort",
        "description": "Current updater device connection."
      },
      "output": {
        "typeRef": "void",
        "description": "Safe disconnect completion."
      },
      "errors": [
        {
          "code": "DEVICE_SAFETY_FAULT",
          "retryability": "conditional",
          "description": "RF-off or close failed."
        }
      ],
      "invariants": [
        "Failure never claims safe disconnect."
      ]
    },
    {
      "capabilityId": "device-list",
      "input": {
        "typeRef": "UpdateDiscoveryPort",
        "description": "Serial discovery capability."
      },
      "output": {
        "typeRef": "PortCandidateArray",
        "description": "Current normalized candidates."
      },
      "errors": [
        {
          "code": "DEVICE_DISCOVERY_FAILED",
          "retryability": "safe",
          "description": "Enumeration failed."
        }
      ],
      "invariants": [
        "Candidates are rebound before connect."
      ]
    },
    {
      "capabilityId": "device-connect",
      "input": {
        "typeRef": "UpdateConnectPort",
        "description": "Connection capability plus one exact candidate."
      },
      "output": {
        "typeRef": "DeviceSnapshot",
        "description": "Admitted ready device."
      },
      "errors": [
        {
          "code": "DEVICE_ADMISSION_FAILED",
          "retryability": "conditional",
          "description": "Physical admission failed."
        }
      ],
      "invariants": [
        "Exact ZS407 identity is required."
      ]
    },
    {
      "capabilityId": "device-connection-composition",
      "input": {
        "typeRef": "UpdateConnectionPort",
        "description": "Disconnect, discovery, and connect composition."
      },
      "output": {
        "typeRef": "UpdateDevice",
        "description": "Complete updater device capability."
      },
      "errors": [],
      "invariants": [
        "All connection mutations are explicit leaf ports."
      ]
    },
    {
      "capabilityId": "updater-fetch",
      "input": {
        "typeRef": "UpdaterArtifactFetchPort",
        "description": "Updater network fetch capability."
      },
      "output": {
        "typeRef": "ReadableByteResponse",
        "description": "Untrusted response."
      },
      "errors": [
        {
          "code": "FIRMWARE_SOURCE_FAILED",
          "retryability": "safe",
          "description": "Fetch failed."
        }
      ],
      "invariants": [
        "Only OEM targets use network fetch."
      ]
    },
    {
      "capabilityId": "updater-verify-artifact",
      "input": {
        "typeRef": "UpdaterArtifactVerificationPort",
        "description": "Updater OEM verifier capability."
      },
      "output": {
        "typeRef": "void",
        "description": "Successful pinned verification."
      },
      "errors": [
        {
          "code": "ARTIFACT_REJECTED",
          "retryability": "never",
          "description": "OEM bytes mismatch."
        }
      ],
      "invariants": [
        "Verifier is required independently of fetch."
      ]
    },
    {
      "capabilityId": "updater-artifact-composition",
      "input": {
        "typeRef": "UpdaterArtifactPort",
        "description": "Fetch and verification composition."
      },
      "output": {
        "typeRef": "FirmwareUpdaterRuntime",
        "description": "Complete updater runtime when combined with time and DFU ports."
      },
      "errors": [],
      "invariants": [
        "No composite hides an optional leaf dependency."
      ]
    },
    {
      "capabilityId": "updater-now",
      "input": {
        "typeRef": "FirmwareClockPort",
        "description": "Updater clock."
      },
      "output": {
        "typeRef": "Date",
        "description": "Valid current Date."
      },
      "errors": [
        {
          "code": "INVALID_RUNTIME_VALUE",
          "retryability": "never",
          "description": "Clock is invalid."
        }
      ],
      "invariants": [
        "Persisted timestamps are ISO instants."
      ]
    },
    {
      "capabilityId": "updater-random-uuid",
      "input": {
        "typeRef": "FirmwareIdentityPort",
        "description": "Updater identity source."
      },
      "output": {
        "typeRef": "UuidV4",
        "description": "UUID-v4 preparation identity."
      },
      "errors": [
        {
          "code": "INVALID_RUNTIME_VALUE",
          "retryability": "never",
          "description": "Identity is invalid."
        }
      ],
      "invariants": [
        "Preparation and lock identities are unpredictable in production."
      ]
    },
    {
      "capabilityId": "updater-delay",
      "input": {
        "typeRef": "FirmwareDelayPort",
        "description": "A bounded millisecond delay request."
      },
      "output": {
        "typeRef": "void",
        "description": "Completion after delay."
      },
      "errors": [],
      "invariants": [
        "Delay never changes firmware state itself."
      ]
    },
    {
      "capabilityId": "updater-time-composition",
      "input": {
        "typeRef": "FirmwareTimeAndIdentityPort",
        "description": "Clock, identity, and delay composition."
      },
      "output": {
        "typeRef": "FirmwareUpdaterRuntime",
        "description": "Complete runtime when combined with artifact and DFU ports."
      },
      "errors": [],
      "invariants": [
        "Nondeterminism remains injectable."
      ]
    },
    {
      "capabilityId": "admitted-artifact-open-verified",
      "input": {
        "typeRef": "AdmittedFirmwareArtifact",
        "description": "A target-ID-bound app-owned artifact capability."
