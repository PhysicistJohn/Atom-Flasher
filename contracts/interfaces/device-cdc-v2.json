{
  "$schema": "../schemas/interface-contract-v2.schema.json",
  "contractId": "tinysa-flasher-device-cdc",
  "contractVersion": 2,
  "kind": "transport",
  "owner": "device-admission",
  "provider": "SerialTransport, CommandScheduler, and Zs407DeviceService",
  "consumers": [
    "FlasherApplication",
    "FirmwareUpdater"
  ],
  "compatibility": "exact-version",
  "typeDefinitions": {
    "ByteTransport": {
      "sourceModule": "src/device/protocol.ts",
      "typeExport": "ByteTransport",
      "sourceSignature": "export interface ByteTransport { open(path: string): Promise<void>; close(): Promise<void>; discardInput(): Promise<void>; write(bytes: Uint8Array): Promise<void>; onBytes(listener: (bytes: Uint8Array) => void): () => void; onEvent(listener: (event: TransportEvent) => void): () => void; }"
    },
    "DeviceTransport": {
      "sourceModule": "src/device/device-service.ts",
      "typeExport": "DeviceTransport",
      "sourceSignature": "export interface DeviceTransport extends ByteTransport { list(): Promise<PortCandidate[]>; }"
    },
    "CommandScheduler": {
      "sourceModule": "src/device/protocol.ts",
      "typeExport": "CommandScheduler",
      "sourceSignature": "class CommandScheduler { execute(command: string, timeoutMs: number = 10_000): Promise<string>; executeBinary(command: string, payloadBytes: number, timeoutMs: number = 20_000): Promise<Uint8Array>; dispose(): void }"
    },
    "Zs407DeviceService": {
      "sourceModule": "src/device/device-service.ts",
      "typeExport": "Zs407DeviceService",
      "sourceSignature": "class Zs407DeviceService { listDevices(): Promise<PortCandidate[]>; snapshot(): DeviceSnapshot; connect(candidate: PortCandidate): Promise<DeviceSnapshot>; disconnect(): Promise<void>; recoverAfterManualPowerOff(confirmation: typeof MANUAL_POWER_OFF_CONFIRMATION): Promise<DeviceSnapshot>; readDiagnostics(): Promise<DeviceDiagnostics>; captureScreen(): Promise<ScreenFrame> }"
    },
    "Path": {
      "sourceModule": "platform:node",
      "platformType": "string"
    },
    "Uint8Array": {
      "sourceModule": "platform:ecmascript",
      "platformType": "Uint8Array"
    },
    "Unsubscribe": {
      "sourceModule": "platform:ecmascript",
      "platformType": "() => void"
    },
    "TransportEvent": {
      "sourceModule": "src/device/protocol.ts",
      "typeExport": "TransportEvent",
      "sourceSignature": "export type TransportEvent = | { type: 'opened' } | { type: 'closed'; reason?: string } | { type: 'error'; error: Error };"
    },
    "PortCandidateArray": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "portCandidateArraySchema",
      "typeExport": "PortCandidateArray",
      "sourceSignature": "export type PortCandidateArray = z.infer<typeof portCandidateArraySchema>;"
    },
    "PortCandidate": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "portCandidateSchema",
      "typeExport": "PortCandidate",
      "sourceSignature": "export type PortCandidate = z.infer<typeof portCandidateSchema>;"
    },
    "DeviceSnapshot": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "deviceSnapshotSchema",
      "typeExport": "DeviceSnapshot",
      "sourceSignature": "export type DeviceSnapshot = z.infer<typeof deviceSnapshotSchema>;"
    },
    "DeviceDiagnostics": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "deviceDiagnosticsSchema",
      "typeExport": "DeviceDiagnostics",
      "sourceSignature": "export type DeviceDiagnostics = z.infer<typeof deviceDiagnosticsSchema>;"
    },
    "ScreenFrame": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "screenFrameSchema",
      "typeExport": "ScreenFrame",
      "sourceSignature": "export type ScreenFrame = z.infer<typeof screenFrameSchema>;"
    },
    "TextResponse": {
      "sourceModule": "platform:ecmascript",
      "platformType": "string"
    },
    "void": {
      "sourceModule": "platform:ecmascript",
      "platformType": "void"
    }
  },
  "capabilities": [
    {
      "capabilityId": "transport-open",
      "input": {
        "typeRef": "Path",
        "description": "One serial device path."
      },
      "output": {
        "typeRef": "void",
        "description": "Transport open completion."
      },
      "errors": [
        {
          "code": "SERIAL_OPEN_FAILED",
          "retryability": "conditional",
          "description": "Serial path could not be opened."
        }
      ],
      "invariants": [
        "Only one live transport session is admitted."
      ]
    },
    {
      "capabilityId": "transport-close",
      "input": {
        "typeRef": "ByteTransport",
        "description": "Current byte transport."
      },
      "output": {
        "typeRef": "void",
        "description": "Transport close completion."
      },
      "errors": [
        {
          "code": "SERIAL_CLOSE_FAILED",
          "retryability": "conditional",
          "description": "Transport could not close cleanly."
        }
      ],
      "invariants": [
        "Terminal close invalidates the command scheduler."
      ]
    },
    {
      "capabilityId": "transport-discard-input",
      "input": {
        "typeRef": "ByteTransport",
        "description": "Open byte transport before a command write."
      },
      "output": {
        "typeRef": "void",
        "description": "All previously buffered input discarded."
      },
      "errors": [
        {
          "code": "SERIAL_PROTOCOL_DESYNCHRONIZED",
          "retryability": "never",
          "description": "Input could not be flushed safely."
        }
      ],
      "invariants": [
        "Every command opens its response window only after this flush and its own write."
      ]
    },
    {
      "capabilityId": "transport-write",
      "input": {
        "typeRef": "Uint8Array",
        "description": "Exact command bytes."
      },
      "output": {
        "typeRef": "void",
        "description": "Write completion."
      },
      "errors": [
        {
          "code": "SERIAL_WRITE_FAILED",
          "retryability": "never",
          "description": "Command bytes were not accepted."
        }
      ],
      "invariants": [
        "Commands are serialized by CommandScheduler."
      ]
    },
    {
      "capabilityId": "transport-on-bytes",
      "input": {
        "typeRef": "ByteTransport",
        "description": "A byte listener."
      },
      "output": {
        "typeRef": "Unsubscribe",
        "description": "Listener removal capability."
      },
      "errors": [],
      "invariants": [
        "Unsolicited bytes outside a response window permanently fault the scheduler."
      ]
    },
    {
      "capabilityId": "transport-on-event",
      "input": {
        "typeRef": "TransportEvent",
        "description": "A terminal/open event listener."
      },
      "output": {
        "typeRef": "Unsubscribe",
        "description": "Listener removal capability."
      },
      "errors": [],
      "invariants": [
        "Close and error are terminal for all queued commands."
      ]
    },
    {
      "capabilityId": "transport-list",
      "input": {
        "typeRef": "DeviceTransport",
        "description": "Host serial enumerator."
      },
      "output": {
        "typeRef": "PortCandidateArray",
        "description": "Normalized current candidates."
      },
      "errors": [
        {
          "code": "SERIAL_DISCOVERY_FAILED",
          "retryability": "safe",
          "description": "Enumeration failed."
        }
      ],
      "invariants": [
        "Only exact 0483:5740 candidates receive the exact-zs407-cdc label."
      ]
    },
    {
      "capabilityId": "scheduler-execute",
      "input": {
        "typeRef": "CommandScheduler",
        "description": "One 1..47 byte printable-ASCII command and timeout."
      },
      "output": {
        "typeRef": "TextResponse",
        "description": "Strict UTF-8 response framed by exact echo and prompt."
      },
      "errors": [
        {
          "code": "SERIAL_PROTOCOL_DESYNCHRONIZED",
          "retryability": "never",
          "description": "Timeout, overflow, framing, UTF-8, or terminal event failed."
        }
      ],
      "invariants": [
        "Unexpected trailing bytes after a complete response fault the scheduler."
      ]
    },
    {
      "capabilityId": "scheduler-execute-binary",
      "input": {
        "typeRef": "CommandScheduler",
        "description": "Printable command, exact payload length, and timeout."
      },
      "output": {
        "typeRef": "Uint8Array",
        "description": "Exact-length binary payload."
      },
      "errors": [
        {
          "code": "SERIAL_PROTOCOL_DESYNCHRONIZED",
          "retryability": "never",
          "description": "Binary framing or length failed."
        }
      ],
      "invariants": [
        "Payload length is exact before the prompt."
      ]
    },
    {
      "capabilityId": "scheduler-dispose",
      "input": {
        "typeRef": "CommandScheduler",
        "description": "Live command scheduler."
      },
      "output": {
        "typeRef": "void",
        "description": "Terminal disposal completion."
      },
      "errors": [],
      "invariants": [
        "Active and queued commands reject after disposal."
      ]
    },
    {
      "capabilityId": "device-list",
      "input": {
        "typeRef": "Zs407DeviceService",
        "description": "Device service discovery request."
      },
      "output": {
        "typeRef": "PortCandidateArray",
        "description": "Current candidates."
      },
      "errors": [
        {
          "code": "SERIAL_DISCOVERY_FAILED",
          "retryability": "safe",
          "description": "Enumeration failed."
        }
      ],
      "invariants": [
        "No connection is created by discovery."
      ]
    },
    {
      "capabilityId": "device-snapshot",
      "input": {
        "typeRef": "Zs407DeviceService",
        "description": "Current device service."
      },
      "output": {
        "typeRef": "DeviceSnapshot",
        "description": "Cloned strict state."
      },
      "errors": [],
      "invariants": [
        "Callers cannot mutate owned state."
      ]
    },
    {
      "capabilityId": "device-connect",
      "input": {
        "typeRef": "PortCandidate",
        "description": "Candidate rebound to the current enumeration."
      },
      "output": {
        "typeRef": "DeviceSnapshot",
        "description": "Exact admitted ready state."
      },
      "errors": [
        {
          "code": "DEVICE_ADMISSION_FAILED",
          "retryability": "conditional",
          "description": "USB, firmware identity, command surface, telemetry, or RF-off admission failed."
        }
      ],
      "invariants": [
        "RF output off is commanded before and after identity inspection."
      ]
    },
    {
      "capabilityId": "device-disconnect",
      "input": {
        "typeRef": "Zs407DeviceService",
        "description": "Current device service."
      },
      "output": {
        "typeRef": "void",
        "description": "Safe disconnected state."
      },
      "errors": [
        {
          "code": "DEVICE_SAFETY_FAULT",
          "retryability": "conditional",
          "description": "RF-off or close could not be confirmed."
        }
      ],
      "invariants": [
        "Failure enters explicit faulted state."
      ]
    },
    {
      "capabilityId": "device-recover-after-power-off",
      "input": {
        "typeRef": "Zs407DeviceService",
        "description": "Faulted service plus exact internal confirmation literal."
      },
      "output": {
        "typeRef": "DeviceSnapshot",
        "description": "Recovered disconnected state."
      },
      "errors": [
        {
          "code": "DEVICE_SAFETY_FAULT",
          "retryability": "conditional",
          "description": "Fault is ineligible for manual recovery."
        }
      ],
      "invariants": [
        "Confirmation is supplied only after an independent native prompt."
      ]
    },
    {
      "capabilityId": "device-read-diagnostics",
      "input": {
        "typeRef": "Zs407DeviceService",
        "description": "Admitted ready device."
      },
      "output": {
        "typeRef": "DeviceDiagnostics",
        "description": "Exact live diagnostic evidence."
      },
      "errors": [
        {
          "code": "DEVICE_SAFETY_FAULT",
          "retryability": "conditional",
          "description": "Live session or commands failed."
        }
      ],
      "invariants": [
        "RF output is off during observation."
      ]
    },
    {
      "capabilityId": "device-capture-screen",
      "input": {
        "typeRef": "Zs407DeviceService",
        "description": "Admitted ready device."
      },
      "output": {
        "typeRef": "ScreenFrame",
        "description": "Exact 307200-byte RGB565 frame."
      },
      "errors": [
        {
          "code": "SCREEN_CAPTURE_FAILED",
          "retryability": "conditional",
          "description": "Binary capture failed."
        }
      ],
      "invariants": [
        "RF output off is confirmed immediately before capture."
      ]
    }
  ],
