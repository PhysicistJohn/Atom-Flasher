{
  "$schema": "../schemas/interface-contract-v2.schema.json",
  "contractId": "tinysa-flasher-legacy-migration",
  "contractVersion": 1,
  "kind": "migration",
  "owner": "firmware-transaction-evidence",
  "provider": "migrateLegacyFirmwareState",
  "consumers": [
    "application startup"
  ],
  "compatibility": "exact-version",
  "typeDefinitions": {
    "LegacyEvidenceLocations": {
      "sourceModule": "src/core/legacy-migration.ts",
      "platformType": "{ targetDirectory: string; legacyDirectories: readonly string[] }"
    },
    "LegacyMigrationResult": {
      "sourceModule": "src/core/legacy-migration.ts",
      "typeExport": "LegacyMigrationResult",
      "sourceSignature": "export interface LegacyMigrationResult { status: 'none' | 'imported' | 'already-current' | 'conflict'; sources: readonly string[]; message?: string; }"
    }
  },
  "capabilities": [
    {
      "capabilityId": "import-once",
      "input": {
        "typeRef": "LegacyEvidenceLocations",
        "description": "Standalone target and the two known Atomizer firmware directories."
      },
      "output": {
        "typeRef": "LegacyMigrationResult",
        "description": "Discriminated none, imported, already-current, or conflict result."
      },
      "errors": [
        {
          "code": "LEGACY_EVIDENCE_CONFLICT",
          "retryability": "manual-inspection",
          "description": "Histories differ, are malformed, drifted, locked, or structurally unsafe."
        }
      ],
      "invariants": [
        "Sources are never deleted or selected by recency.",
        "Identical evidence is copied create-once and a durable consumed-hash marker prevents resurrection."
      ]
    }
  ],
  "sourceProjections": [
    {
      "sourceModule": "src/core/legacy-migration.ts",
      "symbol": "migrateLegacyFirmwareState",
      "symbolKind": "function",
      "members": [
        {
          "sourceMember": "migrateLegacyFirmwareState",
          "capabilityId": "import-once",
          "sourceSignature": "migrateLegacyFirmwareState(targetDirectory: string, legacyDirectories: readonly string[]): Promise<LegacyMigrationResult>"
        }
      ]
    }
  ],
  "sourceOfTruth": [
    "src/core/legacy-migration.ts",
    "src/core/persistence/evidence-schemas-v1.ts",
    "src/core/persistence/evidence-layout.ts"
  ]
}
