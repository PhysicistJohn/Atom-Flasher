{
  "$schema": "../schemas/interface-contract-v2.schema.json",
  "contractId": "tinysa-flasher-ipc-adapter",
  "contractVersion": 1,
  "kind": "runtime-port",
  "owner": "desktop-composition-root",
  "provider": "registerApplicationIpc",
  "consumers": [
    "Electron main process"
  ],
  "compatibility": "exact-version",
  "typeDefinitions": {
    "ApplicationIpcPort": {
      "sourceModule": "src/main/ipc-handlers.ts",
      "typeExport": "ApplicationIpcPort",
      "sourceSignature": "export interface ApplicationIpcPort { snapshot(): ApplicationSnapshot; scanDevices(): Promise<ApplicationActionResult>; connectDevice(candidate: PortCandidate): Promise<ApplicationActionResult>; disconnectDevice(): Promise<ApplicationActionResult>; recoverDevice(): Promise<ApplicationActionResult>; selectOemTarget(): Promise<ApplicationActionResult>; selectLocalFirmwareTarget(): Promise<ApplicationActionResult>; download(): Promise<ApplicationActionResult>; prepare(preflight: FirmwareUpdatePreflight): Promise<ApplicationActionResult>; detectDfu(): Promise<ApplicationActionResult>; refreshPrerequisites(): Promise<ApplicationActionResult>; flash(preparationId: string): Promise<ApplicationActionResult>; }"
    },
    "IpcRegistrar": {
      "sourceModule": "src/main/ipc-handlers.ts",
      "typeExport": "IpcRegistrar",
      "sourceSignature": "export interface IpcRegistrar<Event = unknown> { handle(channel: string, listener: (event: Event, ...args: unknown[]) => Promise<unknown>): void; removeHandler(channel: string): void; }"
    },
    "ApplicationIpcDependencies": {
      "sourceModule": "src/main/ipc-handlers.ts",
      "typeExport": "ApplicationIpcDependencies",
      "sourceSignature": "export interface ApplicationIpcDependencies<Event = unknown> { registrar: IpcRegistrar<Event>; application: ApplicationIpcPort; isTrusted(event: Event): boolean; }"
    },
    "ApplicationSnapshot": {
      "sourceModule": "src/application/application-contract.ts",
      "runtimeValidator": "applicationSnapshotSchema",
      "typeExport": "ApplicationSnapshot",
      "sourceSignature": "export type ApplicationSnapshot = z.infer<typeof applicationSnapshotSchema>;"
    },
    "ApplicationActionResult": {
      "sourceModule": "src/application/application-contract.ts",
      "runtimeValidator": "applicationActionResultSchema",
      "typeExport": "ApplicationActionResult",
      "sourceSignature": "export type ApplicationActionResult = z.infer<typeof applicationActionResultSchema>;"
    },
    "PortCandidate": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "portCandidateSchema",
      "typeExport": "PortCandidate",
      "sourceSignature": "export type PortCandidate = z.infer<typeof portCandidateSchema>;"
    },
    "FirmwareUpdatePreflight": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "firmwareUpdatePreflightSchema",
      "typeExport": "FirmwareUpdatePreflight",
      "sourceSignature": "export type FirmwareUpdatePreflight = z.infer<typeof firmwareUpdatePreflightSchema>;"
    },
    "PreparationId": {
      "sourceModule": "src/core/contracts.ts",
      "runtimeValidator": "uuidSchema",
      "platformType": "string"
    },
    "boolean": {
      "sourceModule": "platform:ecmascript",
      "platformType": "boolean"
    },
    "void": {
      "sourceModule": "platform:ecmascript",
      "platformType": "void"
    }
  },
  "capabilities": [
    {
      "capabilityId": "application-snapshot",
      "input": {
        "typeRef": "ApplicationIpcPort",
        "description": "Domain-facing application facade."
      },
      "output": {
        "typeRef": "ApplicationSnapshot",
        "description": "Strict aggregate snapshot."
      },
      "errors": [
        {
          "code": "OPERATION_FAILED",
          "retryability": "never",
          "description": "The facade could not produce valid state."
        }
      ],
      "invariants": [
        "Adapter validates the output before reply serialization."
      ]
    },
    {
      "capabilityId": "application-scan-devices",
      "input": {
        "typeRef": "ApplicationIpcPort",
        "description": "Domain-facing application facade."
      },
      "output": {
        "typeRef": "ApplicationActionResult",
        "description": "Scan result."
      },
      "errors": [
        {
          "code": "OPERATION_BUSY",
          "retryability": "safe",
          "description": "Operation admission rejected the request."
        }
      ],
      "invariants": [
        "Only the contracted no-argument request reaches the facade."
      ]
    },
    {
      "capabilityId": "application-connect-device",
      "input": {
        "typeRef": "PortCandidate",
        "description": "One strict candidate."
      },
      "output": {
        "typeRef": "ApplicationActionResult",
        "description": "Connection result."
      },
      "errors": [
        {
          "code": "DEVICE_ADMISSION_FAILED",
          "retryability": "conditional",
          "description": "Physical admission failed."
        }
      ],
      "invariants": [
        "Candidate is parsed before invocation."
      ]
    },
    {
      "capabilityId": "application-disconnect-device",
      "input": {
        "typeRef": "ApplicationIpcPort",
        "description": "Domain-facing application facade."
      },
      "output": {
        "typeRef": "ApplicationActionResult",
        "description": "Disconnect result."
      },
      "errors": [
        {
          "code": "DEVICE_SAFETY_FAULT",
          "retryability": "conditional",
          "description": "Safe disconnect failed."
        }
      ],
      "invariants": [
        "No arguments are accepted."
      ]
    },
    {
      "capabilityId": "application-recover-device",
      "input": {
        "typeRef": "ApplicationIpcPort",
        "description": "Domain-facing application facade."
      },
      "output": {
        "typeRef": "ApplicationActionResult",
        "description": "Native-confirmed recovery result."
      },
      "errors": [
        {
          "code": "DEVICE_SAFETY_FAULT",
          "retryability": "conditional",
          "description": "Recovery failed."
        }
      ],
      "invariants": [
        "Renderer input cannot supply the confirmation literal."
      ]
    },
    {
      "capabilityId": "application-select-oem-target",
      "input": {
        "typeRef": "ApplicationIpcPort",
        "description": "Domain-facing application facade."
      },
      "output": {
        "typeRef": "ApplicationActionResult",
        "description": "OEM selection result."
      },
      "errors": [
        {
          "code": "UPDATE_PRECONDITION_FAILED",
          "retryability": "conditional",
          "description": "Target selection is locked."
        }
      ],
      "invariants": [
        "No arguments are accepted."
      ]
    },
    {
      "capabilityId": "application-select-local-firmware-target",
      "input": {
        "typeRef": "ApplicationIpcPort",
        "description": "Domain-facing application facade."
      },
      "output": {
        "typeRef": "ApplicationActionResult",
        "description": "Cancelled or completed native selection result."
      },
      "errors": [
        {
          "code": "OPERATION_FAILED",
          "retryability": "never",
          "description": "Native selection or admission failed."
        }
      ],
      "invariants": [
        "No renderer-controlled path or manifest bytes enter the call."
      ]
    },
    {
      "capabilityId": "application-download",
      "input": {
        "typeRef": "ApplicationIpcPort",
        "description": "Domain-facing application facade."
      },
      "output": {
        "typeRef": "ApplicationActionResult",
        "description": "OEM download result."
      },
      "errors": [
        {
          "code": "FIRMWARE_SOURCE_FAILED",
          "retryability": "safe",
          "description": "Fetch or verification failed."
        }
      ],
      "invariants": [
        "No arguments are accepted."
      ]
    },
    {
      "capabilityId": "application-prepare",
      "input": {
        "typeRef": "FirmwareUpdatePreflight",
        "description": "Strict preflight tuple value."
      },
      "output": {
        "typeRef": "ApplicationActionResult",
        "description": "Preparation result."
      },
      "errors": [
        {
          "code": "PREFLIGHT_FAILED",
          "retryability": "conditional",
          "description": "Preparation failed."
        }
      ],
      "invariants": [
        "Input is parsed before invocation."
      ]
    },
    {
      "capabilityId": "application-detect-dfu",
      "input": {
        "typeRef": "ApplicationIpcPort",
        "description": "Domain-facing application facade."
      },
      "output": {
        "typeRef": "ApplicationActionResult",
        "description": "DFU detection result."
      },
      "errors": [
        {
          "code": "DFU_ADMISSION_FAILED",
          "retryability": "conditional",
          "description": "DFU admission failed."
        }
      ],
      "invariants": [
        "No arguments are accepted."
      ]
    },
    {
      "capabilityId": "application-refresh-prerequisites",
      "input": {
        "typeRef": "ApplicationIpcPort",
        "description": "Domain-facing application facade."
      },
      "output": {
        "typeRef": "ApplicationActionResult",
        "description": "Prerequisite refresh result."
      },
      "errors": [
        {
          "code": "DFU_ADMISSION_FAILED",
          "retryability": "conditional",
          "description": "Prerequisite inspection failed."
        }
      ],
      "invariants": [
        "No arguments are accepted."
      ]
    },
    {
      "capabilityId": "application-flash",
      "input": {
        "typeRef": "PreparationId",
        "description": "Active preparation UUID only."
      },
      "output": {
        "typeRef": "ApplicationActionResult",
        "description": "Native-confirmed write result."
      },
      "errors": [
        {
          "code": "WRITE_INDETERMINATE",
          "retryability": "manual-inspection",
          "description": "Write completion cannot be proven."
        }
      ],
      "invariants": [
        "Renderer input never includes a confirmation literal."
      ]
    },
    {
      "capabilityId": "registrar-handle",
      "input": {
        "typeRef": "IpcRegistrar",
        "description": "Registrar plus one unique contracted channel and handler."
      },
      "output": {
        "typeRef": "void",
        "description": "Handler registration completion."
      },
      "errors": [],
      "invariants": [
        "Every handler validates trust, request tuple, output, and wire reply."
      ]
    },
    {
      "capabilityId": "registrar-remove-handler",
      "input": {
        "typeRef": "IpcRegistrar",
        "description": "Registrar plus one registered channel."
      },
      "output": {
        "typeRef": "void",
        "description": "Handler removal completion."
      },
      "errors": [],
      "invariants": [
        "Adapter disposal removes every registry channel."
      ]
    },
    {
      "capabilityId": "dependencies-is-trusted",
      "input": {
        "typeRef": "ApplicationIpcDependencies",
        "description": "Adapter dependencies plus one Electron IPC event."
      },
      "output": {
        "typeRef": "boolean",
        "description": "Whether the event belongs to the installed trusted frame and origin."
      },
      "errors": [],
      "invariants": [
        "Untrusted events are rejected before request parsing or domain invocation."
      ]
    }
  ],
