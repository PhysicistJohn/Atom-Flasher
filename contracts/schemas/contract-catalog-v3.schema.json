{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://physicistjohn.github.io/tinysa-flasher/contracts/contract-catalog-v3.schema.json",
  "title": "TinySA Flasher contract catalog v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "$id",
    "contractId",
    "contractVersion",
    "applicationContract",
    "applicationContractSha256",
    "interfaceEnvelopeVersion",
    "interfaces"
  ],
  "properties": {
    "$schema": { "const": "./schemas/contract-catalog-v3.schema.json" },
    "$id": { "const": "https://physicistjohn.github.io/tinysa-flasher/contracts/contract-catalog-v3.json" },
    "contractId": { "const": "tinysa-flasher-contract-catalog" },
    "contractVersion": { "const": 3 },
    "applicationContract": { "const": "./flasher-application-v2.json" },
    "applicationContractSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "interfaceEnvelopeVersion": { "const": 3 },
    "interfaces": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["contractId", "contractVersion", "path", "sha256", "required"],
        "properties": {
          "contractId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "contractVersion": { "const": 3 },
          "path": { "type": "string", "pattern": "^\\./interfaces/[a-z0-9-]+-v3\\.json$" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "required": { "const": true }
        }
      }
    }
  }
}
