{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://physicistjohn.github.io/tinysa-flasher/contracts/contract-catalog-v2.schema.json",
  "title": "TinySA Flasher contract catalog v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "$id", "contractId", "contractVersion", "applicationContract", "interfaces"],
  "properties": {
    "$schema": { "const": "./schemas/contract-catalog-v2.schema.json" },
    "$id": { "const": "https://physicistjohn.github.io/tinysa-flasher/contracts/contract-catalog-v2.json" },
    "contractId": { "const": "tinysa-flasher-contract-catalog" },
    "contractVersion": { "const": 2 },
    "applicationContract": { "const": "./flasher-application-v2.json" },
    "interfaces": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["contractId", "contractVersion", "path", "sha256", "required"],
        "properties": {
          "contractId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "contractVersion": { "type": "integer", "minimum": 1 },
          "path": { "type": "string", "pattern": "^\\./interfaces/[a-z0-9-]+-v[1-9][0-9]*\\.json$" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "required": { "const": true }
        }
      }
    }
  }
}
