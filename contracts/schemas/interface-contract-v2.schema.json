{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://physicistjohn.github.io/tinysa-flasher/contracts/interface-contract-v2.schema.json",
  "title": "TinySA Flasher source-projected decomposable interface contract v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "contractId",
    "contractVersion",
    "kind",
    "owner",
    "provider",
    "consumers",
    "compatibility",
    "typeDefinitions",
    "capabilities",
    "sourceProjections",
    "sourceOfTruth"
  ],
  "properties": {
    "$schema": { "const": "../schemas/interface-contract-v2.schema.json" },
    "contractId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "contractVersion": { "type": "integer", "minimum": 1 },
    "kind": {
      "enum": ["ipc", "domain-service", "transport", "external-service", "persistence", "configuration", "migration", "runtime-port"]
    },
    "owner": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "consumers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "compatibility": { "enum": ["exact-version", "same-major"] },
    "typeDefinitions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/typeDefinition" }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability" }
    },
    "sourceProjections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceProjection" }
    },
    "sourceOfTruth": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "typeDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceModule"],
      "properties": {
        "sourceModule": { "type": "string", "minLength": 1 },
        "runtimeValidator": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$" },
        "runtimeContract": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$" },
        "valueExport": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$" },
        "typeExport": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$" },
        "sourceSignature": { "type": "string", "minLength": 1 },
        "platformType": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "required": ["typeExport"] },
          "then": { "required": ["sourceSignature"] }
        }
      ],
      "anyOf": [
        { "required": ["runtimeValidator"] },
        { "required": ["runtimeContract"] },
        { "required": ["valueExport"] },
        { "required": ["typeExport"] },
        { "required": ["platformType"] }
      ]
    },
    "value": {
      "type": "object",
      "additionalProperties": false,
      "required": ["typeRef", "description"],
      "properties": {
        "typeRef": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "retryability", "description"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
        "retryability": { "enum": ["never", "safe", "conditional", "manual-inspection"] },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capabilityId", "input", "output", "errors", "invariants"],
      "properties": {
        "capabilityId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "channel": { "type": "string", "pattern": "^flasher:[a-z0-9:-]+$" },
        "input": { "$ref": "#/$defs/value" },
        "output": { "$ref": "#/$defs/value" },
        "errors": { "type": "array", "items": { "$ref": "#/$defs/error" } },
        "invariants": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "sourceProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceModule", "symbol", "symbolKind", "members"],
      "properties": {
        "sourceModule": { "type": "string", "pattern": "^src/.+\\.tsx?$" },
        "symbol": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$" },
        "symbolKind": { "enum": ["interface", "class", "function", "ipc-registry"] },
        "members": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sourceMember", "sourceSignature", "capabilityId"],
            "properties": {
              "sourceMember": { "type": "string", "pattern": "^[A-Za-z_$][A-Za-z0-9_$]*$" },
              "sourceSignature": { "type": "string", "minLength": 1 },
              "capabilityId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
            }
          }
        }
      }
    }
  }
}
