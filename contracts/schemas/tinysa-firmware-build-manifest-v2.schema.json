{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://physicistjohn.github.io/atom-flasher/contracts/schemas/tinysa-firmware-build-manifest-v2.schema.json",
  "title": "AtomOS tinySA ZS407 local firmware build manifest v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "manifestVersion", "artifact", "firmware", "build", "flashPolicy"],
  "properties": {
    "$schema": {
      "const": "https://physicistjohn.github.io/atom-flasher/contracts/schemas/tinysa-firmware-build-manifest-v2.schema.json"
    },
    "manifestVersion": { "const": 2 },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filename", "format", "sizeBytes", "sha256", "loadAddress", "maximumWriteBytes", "initialStackPointer", "resetHandler"],
      "properties": {
        "filename": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*\\.bin$", "maxLength": 160 },
        "format": { "const": "raw-stm32-binary" },
        "sizeBytes": { "type": "integer", "minimum": 8192, "maximum": 245760 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "loadAddress": { "const": "0x08000000" },
        "maximumWriteBytes": { "const": 245760 },
        "initialStackPointer": { "type": "string", "pattern": "^0x[0-9a-f]{8}$" },
        "resetHandler": { "type": "string", "pattern": "^0x[0-9a-f]{8}$" }
      }
    },
    "firmware": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "hardwareTarget", "mcu", "version", "reportedRevision", "sourceRepository", "sourceCommit", "sourceTree", "chibiosCommit"],
      "properties": {
        "product": { "const": "tinySA Ultra / Ultra+" },
        "hardwareTarget": { "const": "ZS407" },
        "mcu": { "const": "STM32F303" },
        "version": { "type": "string", "pattern": "^tinySA4_[A-Za-z0-9.+_-]{1,96}-g[a-f0-9]{7,40}$", "maxLength": 128 },
        "reportedRevision": { "type": "string", "pattern": "^[a-f0-9]{7,40}$" },
        "sourceRepository": { "const": "PhysicistJohn/Atom-Firmware" },
        "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "sourceTree": { "const": "tracked-clean" },
        "chibiosCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceDateEpoch", "toolchain", "reproducibleCleanBuilds", "hardwareQualification", "simulationQualification"],
      "properties": {
        "sourceDateEpoch": { "type": "integer", "minimum": 1 },
        "toolchain": { "type": "string", "minLength": 1, "maxLength": 200 },
        "reproducibleCleanBuilds": { "const": true },
        "hardwareQualification": { "enum": ["unqualified", "qualified-on-zs407"] },
        "simulationQualification": { "enum": ["not-run", "passed"] },
        "qualificationEvidenceSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "allOf": [
        {
          "if": { "properties": { "hardwareQualification": { "const": "qualified-on-zs407" } } },
          "then": { "required": ["qualificationEvidenceSha256"] },
          "else": { "not": { "required": ["qualificationEvidenceSha256"] } }
        }
      ]
    },
    "flashPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["physicalFlash", "automatedFlash", "requiresKnownGoodRollback"],
      "properties": {
        "physicalFlash": { "const": "operator-confirmed-only" },
        "automatedFlash": { "const": false },
        "requiresKnownGoodRollback": { "const": true }
      }
    }
  }
}
